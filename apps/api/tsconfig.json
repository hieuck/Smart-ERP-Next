{
  "compilerOptions": {
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "outDir": "./dist",
    "strictPropertyInitialization": false,
    "paths": {
      "@smart-erp/database": ["../../packages/database/src/index.ts"],
      "@smart-erp/database/drizzle": ["../../packages/database/src/drizzle.ts"],
      "@smart-erp/database/schema": [
        "../../packages/database/src/schema/index.ts"
      ]
    },
    "rootDirs": ["./src", "../../packages/database/src"]
  },
  "exclude": ["node_modules", "dist", "src/**/*.spec.ts", "test"],
  "extends": "../../packages/config-typescript/node.json",
  "include": ["src/main.ts", "src/app.module.ts", "src/app.controller.ts", "src/app.service.ts"]
}
